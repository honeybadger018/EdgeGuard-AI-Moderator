import os, warnings
# Set offline mode if models are already downloaded
os.environ['TRANSFORMERS_OFFLINE'] = '1' 
# Suppress HuggingFace warnings for cleaner terminal output
warnings.filterwarnings("ignore")

from fastapi import FastAPI
from transformers import (AutoModelForSequenceClassification,
                        AutoTokenizer, PreTrainedModel, 
                        AutoModelForCausalLM,
                        BitsAndBytesConfig)
import torch, faiss, time
from sentence_transformers import SentenceTransformer

# Creating moderater class
class SmartModerator():
    def __init__(self, cls_model_path: str = "cardiffnlp/twitter-roberta-base-offensive", 
                 gen_model_path: str = "Qwen/Qwen2.5-0.5B-Instruct"):
        self.device = "cuda" if torch.cuda.is_available() else 'cpu'
        # Classification model
        self.cls_tokenizer = AutoTokenizer.from_pretrained(cls_model_path)
        self.cls_tokenizer.pad_token_id = self.cls_tokenizer.eos_token_id
         
        self.model_class:PreTrainedModel = AutoModelForSequenceClassification.from_pretrained(cls_model_path).to(self.device)
        self.model_class.config.pad_token_id = self.cls_tokenizer.pad_token_id

        # Generative model
        self.gen_tokenizer = AutoTokenizer.from_pretrained(gen_model_path)
        self.gen_tokenizer.pad_token_id = self.gen_tokenizer.eos_token_id
        # Apply 4-bit NF4 Quantization if using CUDA
        if self.device == "cuda":
            quantization_config = BitsAndBytesConfig(
                load_in_4bit=True,
                bnb_4bit_quant_type="nf4",
                bnb_4bit_compute_dtype=torch.float16
            )
            self.model_gen: PreTrainedModel = AutoModelForCausalLM.from_pretrained(
                gen_model_path, 
                quantization_config=quantization_config,
                device_map="auto"
            )
        else:
            # Fallback for CPU-only systems
            self.model_gen: PreTrainedModel = AutoModelForCausalLM.from_pretrained(gen_model_path).to(self.device)
        self.model_gen.config.pad_token_id = self.gen_tokenizer.pad_token_id
        # Embedding model
        self.embedding_model = SentenceTransformer("all-MiniLM-L6-v2")
        # FAISS
        self.embed_length = 384
        self.faiss_index = faiss.IndexFlatL2(self.embed_length)
        # Creating a dictionary of comments
        self.text_database = {}
        self.db_counter = 0
        print("Loading...", end="", flush=True)
        time.sleep(1)
        for _ in range(3):
            time.sleep(0.2)
            print("🟢", end=' ', flush=True)
            time.sleep(0.3)
        print(f"System Online using {self.device} ✅")
    
    def moderate(self, user_id:str, comment:str):
            # assuming id2label as 0: Bad, 1: Good
            comment_ids = self.cls_tokenizer(comment,
                                        truncation=True, 
                                        padding='max_length', 
                                        max_length=128, 
                                        return_tensors='pt',
                                        ).to(self.device)
            with torch.no_grad():
                output = self.model_class(**comment_ids)
            logits = output.logits
            probability = torch.softmax(input=logits, dim=-1)
            prediction = torch.argmax(probability, dim=-1).item()
            if prediction == 0:
                return f"Comment: '{comment}' ----> Posted ✅"
            # Here we check and process the bad comment
            db_entry = f"User_id: {user_id} | Comment: {comment}"
            query_vector = self.embedding_model.encode(db_entry).astype('float32').reshape(1, -1)
            warning_response = "This is a warning for an inappropriate comment posted by you ❌"
            if self.faiss_index.ntotal > 0:
                search_k = min(10, self.faiss_index.ntotal)
                distances, indexes = self.faiss_index.search(query_vector, k=search_k)
                previous_offense = None
                for idx in indexes[0]:
                    if idx != -1 and self.text_database[idx]['user_id'] == user_id:
                       previous_offense = self.text_database[idx]['comment']
                       break
                if previous_offense:
                    # print(previous_offense)
                    # 3. Generate Custom Warning using Chat Templates
                    messages =[
                        {"role": "system", "content": "You are a strict automated moderator. The user has repeated a toxic offense. Write exactly one short sentence warning them that they will be banned if this continues."},
                        {"role": "user", "content": f"My past comment: '{previous_offense}'. My new comment: '{comment}'."}
                    ]
                    
                    # Apply the chat template safely
                    prompt = self.gen_tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
                    toks = self.gen_tokenizer(prompt, return_tensors='pt').to(self.device)
                    
                    with torch.no_grad():
                        output_ids = self.model_gen.generate(
                            **toks,
                            pad_token_id=self.gen_tokenizer.eos_token_id,
                            max_new_tokens=50,          # Give it enough room to finish a sentence
                            do_sample=True,             # Allow a little bit of variance
                            temperature=0.3,            # Keep it strict and focused
                            repetition_penalty=1.2      # Stop the AI from stuttering
                        )
                    
                    # Cut out the prompt so we ONLY get the AI's new response
                    input_length = toks.input_ids.shape[1]
                    generated_ids = output_ids[0][input_length:]
                    
                    # Decode the response cleanly
                    final_warning = self.gen_tokenizer.decode(generated_ids, skip_special_tokens=True).strip()
                    
                    warning_response = f"Warning for repeated offense:\n{final_warning} 🚫"
                   
            # Now we will log this
            self.faiss_index.add(query_vector)
            self.text_database[self.db_counter] = {'user_id': user_id, 'comment': comment}
            self.db_counter += 1
            return warning_response

if __name__ == "__main__":
    moderator = SmartModerator()
    # Test 1: A normal comment
    print("\n--- Test 1 ---")
    res1 = moderator.moderate("user_123", "This is a really helpful tutorial, thanks!")
    print(res1)
    
    # Test 2: First toxic comment (Should just get added to DB and generate a generic warning)
    print("\n--- Test 2 ---")
    res2 = moderator.moderate("user_456", "You are completely stupid and I hate this.")
    print(res2)
    
    # Test 3: Repeated toxic comment by the SAME user (Should trigger RAG retrieval)
    print("\n--- Test 3 ---")
    res3 = moderator.moderate("user_456", "I said you are stupid shut up.")
    print(res3)
